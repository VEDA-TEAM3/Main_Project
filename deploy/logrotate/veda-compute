# /etc/logrotate.d/veda-compute
#
# compute-server 는 채널마다 독립된 작업 디렉터리에서 실행된다 (/opt/veda/ch01, ch02, ...).
# 각 인스턴스는 자기 디렉터리의 veda.csv 에만 append 하고(고정 이름), 회전/압축/보존은 전부
# 이 설정이 담당한다. 와일드카드 ch* 하나로 모든 채널을 처리한다.
#
# [ 왜 copytruncate 가 아니라 create + SIGHUP 인가 ]
# copytruncate 는 "복사 -> 원본 truncate" 사이에 기록된 로그가 유실된다.
# 대신 logrotate 가 파일을 rename 하고 새 파일을 create 한 뒤 postrotate 로 SIGHUP 을 보내면,
# 서버가 reopenLogFile() 로 새 파일을 다시 연다 (유실 구간 없음).
#
# [ 주의 ] hourly 는 "logrotate 가 시간당 1회 실행될 때만" 의미가 있다.
# 배포판 기본 logrotate.timer 는 하루 1회라서, 아래 타이머 오버라이드가 반드시 필요하다:
#   /etc/systemd/system/logrotate.timer.d/hourly.conf 참고 (deploy/logrotate/logrotate-hourly.conf)
# (타이머를 hourly 로 바꿔도 daily/weekly 설정들이 시간당 회전되지는 않는다 --
#  logrotate 는 각 설정의 자체 주기를 따로 검사한다)

/opt/veda/ch*/veda.csv {
    hourly
    rotate 72                   # 72시간 = 3일 보존
    missingok                   # 아직 로그가 없는 채널이 있어도 에러로 취급하지 않음
    notifempty                  # 조용한 채널에서 빈 파일 72개가 쌓이는 것을 방지
    compress                    # gzip -- SD 카드 수명/용량에 가장 크게 기여하는 항목
    delaycompress               # 방금 회전된 파일은 다음 주기에 압축
                                #  (비동기 로거가 rename 직후 남은 배치를 옛 inode 에 쓸 수 있으므로,
                                #   아직 기록 중일 수 있는 파일을 gzip 하지 않기 위함)
    dateext
    dateformat -%Y%m%d-%H       # 시간별 회전이므로 '시'까지 넣어야 같은 날 파일명이 충돌하지 않음
    create 0640 team3 team3       # 실제 서비스 계정으로 교체할 것
    su team3 team3                # 로그 디렉터리가 root 소유가 아니면 필요 (logrotate 3.8+)
    sharedscripts               # 여러 채널이 회전돼도 postrotate 는 한 번만 실행
    postrotate
        # 서비스 유닛 이름은 실제 배포에 맞게 교체할 것 (아래는 템플릿 유닛 가정)
        systemctl kill -s HUP --kill-who=main 'compute-server@*.service' 2>/dev/null || true
        # systemd 를 쓰지 않는다면 대안:
        #   pkill -HUP -x compute-server || true
    endscript
}
